public class Patient {
    String name;
    int age;
    String diagnosis;
    String treatmentHistory;
    Patient next;

    public Patient(String name, int age, String diagnosis, String treatmentHistory) {
        this.name = name;
        this.age = age;
        this.diagnosis = diagnosis;
        this.treatmentHistory = treatmentHistory;
        this.next = null;
    }
}


PATIENT RECORD MANAGEMENT(LINKED LIST) AT
public class PatientRecordManagement {
    private Patient head;

    public void addPatient(String name, int age, String diagnosis, String treatmentHistory) {
        Patient newPatient = new Patient(name, age, diagnosis, treatmentHistory);
        newPatient.next = head;
        head = newPatient;
    }

    public Patient getPatient(String name) {
        Patient current = head;
        while (current != null) {
            if (current.name.equalsIgnoreCase(name)) {
                return current;
            }
            current = current.next;
        }
        return null;
    }

    public boolean removePatient(String name) {
        if (head == null) {
            return false; // No patients to remove
        }

        if (head.name.equalsIgnoreCase(name)) {
            head = head.next; // Remove the head of the list
            return true;
        }

        Patient current = head;
        while (current.next != null) {
            if (current.next.name.equalsIgnoreCase(name)) {
                current.next = current.next.next; // Bypass the patient node
                return true;
            }
            current = current.next;
        }

        return false; // Patient not found
    }

    public void displayPatients() {
        Patient current = head;
        while (current != null) {
            System.out.println("Name: " + current.name + ", Age: " + current.age +
                    ", Diagnosis: " + current.diagnosis + ", Treatment History: " + current.treatmentHistory);
            current = current.next;
        }
    }
}





