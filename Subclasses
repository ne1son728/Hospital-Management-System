import java.util.LinkedList;
import java.util.Queue;

class AppointmentScheduling {
    private Queue<String> appointmentQueue = new LinkedList<>();

    public void scheduleAppointment(String patientName) {
        appointmentQueue.add(patientName);
        System.out.println("Appointment scheduled for " + patientName);
    }

    public String serveNextAppointment() {
        return appointmentQueue.poll();
    }

    public void displayAppointments() {
        System.out.println("Scheduled Appointments: " + appointmentQueue);
    }

    // Getter for appointmentQueue
    public Queue<String> getAppointmentQueue() {
        return appointmentQueue;
    }
}


