import java.util.HashMap;
import java.util.Random;

public class DoctorManagement {
    private HashMap<String, Doctor> doctors = new HashMap<>();
    private static final String[] MONTHS = {
            "Jan", "Feb", "Mar", "Apr", "May", "Jun",
            "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"
    };

    public void addDoctor(String id, String name, String specialization, String availableHours) {
        String availability = getRandomSchedule();
        Doctor doctor = new Doctor(id, name, specialization, availableHours, availability);
        doctors.put(id, doctor); // ID is used as the key in the HashMap
    }

    public Doctor getDoctor(String id) {
        return doctors.get(id);
    }

    public void displayDoctors() {
        for (String id : doctors.keySet()) {
            Doctor doctor = doctors.get(id);
            System.out.println("ID: " + doctor.id + ", Name: " + doctor.name +
                    ", Specialization: " + doctor.specialization +
                    ", Available Hours: " + doctor.availableHours +
                    ", Availability: " + doctor.availability);
        }
    }

    private String getRandomSchedule() {
        Random random = new Random();
        int startMonthIndex = random.nextInt(MONTHS.length);
        int endMonthIndex = random.nextInt(MONTHS.length - startMonthIndex) + startMonthIndex;
        return MONTHS[startMonthIndex] + "-" + MONTHS[endMonthIndex];
    }
}




