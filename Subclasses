Emergency scheduling (HEAPS)
 
import java.util.PriorityQueue;
import java.util.Comparator;

public class EmergencyPatientPrioritization {
    private PriorityQueue<EmergencyPatient> emergencyQueue;

    public EmergencyPatientPrioritization() {
        emergencyQueue = new PriorityQueue<>(Comparator.comparingInt(ep -> -ep.severity));
    }

    public void addEmergencyPatient(String name, int severity) {
        emergencyQueue.add(new EmergencyPatient(name, severity));
        System.out.println("Emergency patient added: " + name + " with severity " + severity);
    }

    public EmergencyPatient serveNextEmergency() {
        return emergencyQueue.poll();
    }

    public void displayEmergencyPatients() {
        System.out.println("Emergency Patients (by severity): " + emergencyQueue);
    }

    static class EmergencyPatient {
        String name;
        int severity;

        public EmergencyPatient(String name, int severity) {
            this.name = name;
            this.severity = severity;
        }
    }
}

