    void styleField(JTextField field) {
        field.setBackground(new Color(240, 247, 255)); field.setForeground(TEXT); field.setCaretColor(TEXT);
        field.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        field.setBorder(BorderFactory.createCompoundBorder(BorderFactory.createLineBorder(BORDER), new EmptyBorder(6, 10, 6, 10)));
        field.setMaximumSize(new Dimension(320, 38)); field.setAlignmentX(LEFT_ALIGNMENT);
    }

    void attemptLogin() {
        String user = usernameField.getText().trim();
        String pass = new String(passwordField.getPassword());
        if (user.length() > 12) { errorLabel.setText("Username must be 12 characters or fewer."); shake(); return; }
        if (!pass.chars().anyMatch(Character::isUpperCase)) { errorLabel.setText("Password must contain at least 1 capital letter."); shake(); return; }
        UserAccount matched = null;
        for (UserAccount ua : ACCOUNTS) { if (ua.username.equals(user) && ua.password.equals(pass)) { matched = ua; break; } }
        if (matched != null) {
            final UserAccount m = matched; dispose();
            SwingUtilities.invokeLater(() -> new HospitalManagementGUI(m, db));
        } else {
            errorLabel.setText("Incorrect username or password."); passwordField.setText(""); shake();
        }
    }

    void shake() {
        Point origin = getLocation();
        javax.swing.Timer timer = new javax.swing.Timer(30, null);
        int[] steps = {-10, 10, -8, 8, -5, 5, -3, 3, 0};
        final int[] i = {0};
        timer.addActionListener(e -> {
            if (i[0] < steps.length) { setLocation(origin.x + steps[i[0]], origin.y); i[0]++; }
            else { setLocation(origin); timer.stop(); }
        });
        timer.start();
    }
}
