            if (!currentUser.role.canAddPatient()) { status("Access denied."); return; }
            try {
                String nm = tfName.getText().trim();
                int age   = Integer.parseInt(tfAge.getText().trim());
                String diag = tfDiag.getText().trim(), hist = tfHist.getText().trim();
                if (nm.isEmpty()) { status("Enter a patient name."); return; }
                if (patientRecords.getPatient(nm) != null) { status("Patient '" + nm + "' already exists."); return; }
                addPatientAndPersist(nm, age, diag, hist, currentUser.username);
                logAndPersist(currentUser.username, currentUser.role.displayName, "Added patient: " + nm);
                refreshPatients(); refreshDashboard();
                tfName.setText(""); tfAge.setText(""); tfDiag.setText(""); tfHist.setText("");
                status("Patient '" + nm + "' added and saved.");
            } catch (NumberFormatException ex) { status("Age must be a number."); }
        });

        btnRemove.addActionListener(e -> {
            if (!currentUser.role.canRemovePatient()) { status("Access denied."); return; }
            int row = table.getSelectedRow(); if (row < 0) { status("Select a patient to remove."); return; }
            String nm = (String) patientModel.getValueAt(row, 0);
            int c = JOptionPane.showConfirmDialog(this, "Remove patient '" + nm + "'? This cannot be undone.",
                    "Confirm", JOptionPane.YES_NO_OPTION, JOptionPane.WARNING_MESSAGE);
            if (c == JOptionPane.YES_OPTION && patientRecords.removePatient(nm)) {
                db.deletePatient(nm);
                logAndPersist(currentUser.username, currentUser.role.displayName, "Removed patient: " + nm);
                refreshPatients(); refreshDashboard();
                status("Patient '" + nm + "' removed.");
            }
        });

        btnSearch.addActionListener(e -> {
            String nm = JOptionPane.showInputDialog(this, "Enter patient name:", "Search", JOptionPane.PLAIN_MESSAGE);
            if (nm == null) return;
            Patient pt = patientRecords.getPatient(nm.trim());
            if (pt != null)
                JOptionPane.showMessageDialog(this,
                        "Name: " + pt.name + "\nAge: " + pt.age + "\nDiagnosis: " + pt.diagnosis +
                                "\nHistory: " + pt.treatmentHistory + "\nAdded: " + pt.addedAt + "  by " + pt.addedBy,
                        "Patient Found", JOptionPane.INFORMATION_MESSAGE);
            else JOptionPane.showMessageDialog(this, "Patient not found.", "Not Found", JOptionPane.WARNING_MESSAGE);
