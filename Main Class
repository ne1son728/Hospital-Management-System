        JButton btnAdd = accentBtn("Add Emergency Patient", DANGER);
        JButton btnServe = accentBtn("Serve Highest Priority", ACCENT);

        btnAdd.addActionListener(e -> {
            String nm = tfName.getText().trim();
            int sev = (Integer) spSeverity.getValue();
            if (nm.isEmpty()) { status("Enter patient name."); return; }
            emergency.add(nm, sev);
            refreshEmergency();
            refreshDashboard();
            tfName.setText("");
            status("Emergency patient '" + nm + "' added with severity " + sev);
        });

        btnServe.addActionListener(e -> {
            EmergencyPatientPrioritization.EP next = emergency.serveNext();
            if (next != null) { refreshEmergency(); refreshDashboard(); status("Served emergency patient: " + next.name);
                JOptionPane.showMessageDialog(this, "Serving: " + next.name + "\nSeverity: " + next.severity, "Emergency Served", JOptionPane.WARNING_MESSAGE); }
            else status("No emergency patients.");
        });

        form.add(label("Patient Name:")); form.add(tfName);
        form.add(label("Severity:")); form.add(spSeverity);
        form.add(btnAdd); form.add(btnServe);

        p.add(styledScroll(table), BorderLayout.CENTER);
        p.add(form, BorderLayout.SOUTH);
        return p;
    }

    void refreshEmergency() {
        emergencyModel.setRowCount(0);
        for (EmergencyPatientPrioritization.EP ep : emergency.getAll())
            emergencyModel.addRow(new Object[]{ep.name, ep.severity});
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    void showPage(String name) { cardLayout.show(contentPanel, name); if (name.equals("dashboard")) refreshDashboard(); }

    JTable styledTable(DefaultTableModel model) {
        JTable table = new JTable(model);
        table.setBackground(CARD);
        table.setForeground(TEXT);
        table.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        table.setRowHeight(30);
        table.setShowGrid(false);
        table.setIntercellSpacing(new Dimension(0, 0));
        table.setSelectionBackground(ACCENT);
        table.setSelectionForeground(Color.WHITE);
        table.getTableHeader().setBackground(SIDEBAR);
        table.getTableHeader().setForeground(SUBTEXT);
        table.getTableHeader().setFont(new Font("Segoe UI", Font.BOLD, 12));
        table.getTableHeader().setBorder(BorderFactory.createMatteBorder(0, 0, 1, 0, BORDER));
        // Alternating rows
        table.setDefaultRenderer(Object.class, new DefaultTableCellRenderer() {
            public Component getTableCellRendererComponent(JTable t, Object v, boolean sel, boolean foc, int row, int col) {
                super.getTableCellRendererComponent(t, v, sel, foc, row, col);
                setBorder(new EmptyBorder(0, 12, 0, 12));
                if (sel) { setBackground(ACCENT); setForeground(Color.WHITE); }
                else { setBackground(row % 2 == 0 ? CARD : new Color(224, 238, 252)); setForeground(TEXT); }
                return this;
            }
        });
        return table;
    }

    JScrollPane styledScroll(JTable table) {
        JScrollPane scroll = new JScrollPane(table);
        scroll.setBackground(CARD);
        scroll.getViewport().setBackground(CARD);
        scroll.setBorder(BorderFactory.createLineBorder(BORDER));
        return scroll;
    }

    JTextField field() {
        JTextField tf = new JTextField(14);
        tf.setBackground(new Color(240, 247, 255));
        tf.setForeground(TEXT);
        tf.setCaretColor(TEXT);
        tf.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        tf.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER), new EmptyBorder(4, 8, 4, 8)));
        return tf;
    }

    JLabel label(String text) {
        JLabel l = new JLabel(text);
        l.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        l.setForeground(SUBTEXT);
        return l;
    }

    JButton accentBtn(String text, Color color) {
        JButton btn = new JButton(text);
        btn.setFont(new Font("Segoe UI", Font.BOLD, 12));
        btn.setBackground(color);
        btn.setForeground(Color.WHITE);
        btn.setBorder(new EmptyBorder(8, 16, 8, 16));
        btn.setFocusPainted(false);
        btn.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        btn.addMouseListener(new MouseAdapter() {
            public void mouseEntered(MouseEvent e) { btn.setBackground(color.darker()); }
            public void mouseExited(MouseEvent e)  { btn.setBackground(color); }
        });
        return btn;
    }

    public static void main(String[] args) {
        try { UIManager.setLookAndFeel(UIManager.getSystemLookAndFeelClassName()); }
        catch (Exception ignored) {}
        SwingUtilities.invokeLater(LoginScreen::new);
    }
}

// ─── Login Screen ─────────────────────────────────────────────────────────────

class LoginScreen extends JFrame {

    static final Color BG      = new Color(240, 247, 255);
    static final Color CARD    = new Color(255, 255, 255);
    static final Color BORDER  = new Color(194, 220, 245);
    static final Color ACCENT  = new Color(0, 120, 212);
    static final Color DANGER  = new Color(209, 52, 56);
    static final Color TEXT    = new Color(23, 42, 69);
    static final Color SUBTEXT = new Color(90, 120, 155);

    JTextField usernameField;
    JPasswordField passwordField;
    JLabel errorLabel;
    JLabel charCountLabel;

    // Stored credentials (username max 7 chars, password needs at least 1 capital)
    static final String ADMIN_USER = "Admin";
    static final String ADMIN_PASS = "Admin123";

    public LoginScreen() {
        setTitle("Hospital Management System — Login");
        setDefaultCloseOperation(EXIT_ON_CLOSE);
        setSize(460, 540);
        setResizable(false);
        setLocationRelativeTo(null);
        getContentPane().setBackground(BG);
        setLayout(new GridBagLayout());

        add(buildLoginCard());
        setVisible(true);
    }

    JPanel buildLoginCard() {
        JPanel card = new JPanel();
        card.setBackground(CARD);
        card.setLayout(new BoxLayout(card, BoxLayout.Y_AXIS));
        card.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER, 1, true),
            new EmptyBorder(40, 40, 40, 40)));
        card.setPreferredSize(new Dimension(360, 420));

        // Icon + Title
        JLabel icon = new JLabel("🏥", SwingConstants.CENTER);
        icon.setFont(new Font("Segoe UI Emoji", Font.PLAIN, 48));
        icon.setAlignmentX(CENTER_ALIGNMENT);

        JLabel title = new JLabel("Hospital MS", SwingConstants.CENTER);
        title.setFont(new Font("Segoe UI", Font.BOLD, 22));
        title.setForeground(TEXT);
        title.setAlignmentX(CENTER_ALIGNMENT);

        JLabel subtitle = new JLabel("Admin Login", SwingConstants.CENTER);
        subtitle.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        subtitle.setForeground(SUBTEXT);
        subtitle.setAlignmentX(CENTER_ALIGNMENT);

        // Username field
        JLabel userLabel = new JLabel("Username");
        userLabel.setFont(new Font("Segoe UI", Font.BOLD, 12));
        userLabel.setForeground(SUBTEXT);
        userLabel.setAlignmentX(LEFT_ALIGNMENT);

        JPanel userRow = new JPanel(new BorderLayout(6, 0));
        userRow.setBackground(CARD);
        userRow.setMaximumSize(new Dimension(280, 38));
        userRow.setAlignmentX(LEFT_ALIGNMENT);

        usernameField = new JTextField();
        styleField(usernameField);

        charCountLabel = new JLabel("0/7");
        charCountLabel.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        charCountLabel.setForeground(SUBTEXT);
        charCountLabel.setHorizontalAlignment(SwingConstants.RIGHT);
        charCountLabel.setPreferredSize(new Dimension(30, 20));

        // Enforce max 7 characters and update counter
        usernameField.addKeyListener(new KeyAdapter() {
            public void keyTyped(KeyEvent e) {
                if (usernameField.getText().length() >= 7) e.consume();
            }
            public void keyReleased(KeyEvent e) {
                int len = usernameField.getText().length();
                charCountLabel.setText(len + "/7");
                charCountLabel.setForeground(len >= 7 ? DANGER : SUBTEXT);
            }
        });

        userRow.add(usernameField, BorderLayout.CENTER);
        userRow.add(charCountLabel, BorderLayout.EAST);

        // Password field
        JLabel passLabel = new JLabel("Password  (must contain at least 1 capital letter)");
        passLabel.setFont(new Font("Segoe UI", Font.BOLD, 12));
        passLabel.setForeground(SUBTEXT);
        passLabel.setAlignmentX(LEFT_ALIGNMENT);

        passwordField = new JPasswordField();
        styleField(passwordField);
        passwordField.setMaximumSize(new Dimension(280, 38));
        passwordField.setAlignmentX(LEFT_ALIGNMENT);

        // Show/hide password toggle
        JCheckBox showPass = new JCheckBox("Show password");
        showPass.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        showPass.setForeground(SUBTEXT);
        showPass.setBackground(CARD);
        showPass.setFocusPainted(false);
        showPass.setAlignmentX(LEFT_ALIGNMENT);
        showPass.addActionListener(e ->
            passwordField.setEchoChar(showPass.isSelected() ? (char) 0 : '●'));

        // Error label
        errorLabel = new JLabel(" ");
        errorLabel.setFont(new Font("Segoe UI", Font.PLAIN, 12));
        errorLabel.setForeground(DANGER);
        errorLabel.setAlignmentX(CENTER_ALIGNMENT);

        // Login button
        JButton loginBtn = new JButton("Login");
        loginBtn.setFont(new Font("Segoe UI", Font.BOLD, 14));
        loginBtn.setBackground(ACCENT);
        loginBtn.setForeground(Color.WHITE);
        loginBtn.setBorder(new EmptyBorder(10, 0, 10, 0));
        loginBtn.setFocusPainted(false);
        loginBtn.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        loginBtn.setMaximumSize(new Dimension(280, 44));
        loginBtn.setAlignmentX(CENTER_ALIGNMENT);
        loginBtn.addMouseListener(new MouseAdapter() {
            public void mouseEntered(MouseEvent e) { loginBtn.setBackground(ACCENT.darker()); }
            public void mouseExited(MouseEvent e)  { loginBtn.setBackground(ACCENT); }
        });
        loginBtn.addActionListener(e -> attemptLogin());

        // Allow Enter key to submit
        passwordField.addActionListener(e -> attemptLogin());
        usernameField.addActionListener(e -> passwordField.requestFocus());

        // Hint label
        JLabel hint = new JLabel("Default: " + ADMIN_USER + " / " + ADMIN_PASS, SwingConstants.CENTER);
        hint.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        hint.setForeground(new Color(160, 190, 220));
        hint.setAlignmentX(CENTER_ALIGNMENT);

        // Assemble
        card.add(icon);
        card.add(Box.createVerticalStrut(8));
        card.add(title);
        card.add(Box.createVerticalStrut(4));
        card.add(subtitle);
        card.add(Box.createVerticalStrut(28));
        card.add(userLabel);
        card.add(Box.createVerticalStrut(4));
        card.add(userRow);
        card.add(Box.createVerticalStrut(16));
        card.add(passLabel);
        card.add(Box.createVerticalStrut(4));
        card.add(passwordField);
        card.add(Box.createVerticalStrut(6));
        card.add(showPass);
        card.add(Box.createVerticalStrut(12));
        card.add(errorLabel);
        card.add(Box.createVerticalStrut(8));
        card.add(loginBtn);
        card.add(Box.createVerticalStrut(12));
        card.add(hint);

        return card;
    }

    void styleField(JTextField field) {
        field.setBackground(new Color(240, 247, 255));
        field.setForeground(TEXT);
        field.setCaretColor(TEXT);
        field.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        field.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER), new EmptyBorder(6, 10, 6, 10)));
        field.setMaximumSize(new Dimension(280, 38));
        field.setAlignmentX(LEFT_ALIGNMENT);
    }

    void attemptLogin() {
        String user = usernameField.getText().trim();
        String pass = new String(passwordField.getPassword());

        // Validate username length
        if (user.length() > 7) {
            errorLabel.setText("Username must be 7 characters or fewer.");
            shake();
            return;
        }

        // Validate password has at least 1 capital letter
        boolean hasCapital = pass.chars().anyMatch(Character::isUpperCase);
        if (!hasCapital) {
            errorLabel.setText("Password must contain at least 1 capital letter.");
            shake();
            return;
        }

        // Check credentials
        if (user.equals(ADMIN_USER) && pass.equals(ADMIN_PASS)) {
            dispose();
            new HospitalManagementGUI();
        } else {
            errorLabel.setText("Incorrect username or password.");
            passwordField.setText("");
            shake();
        }
    }

    // Shake animation on failed login
    void shake() {
        Point origin = getLocation();
        javax.swing.Timer timer = new javax.swing.Timer(30, null);
        int[] steps = {-10, 10, -8, 8, -5, 5, -3, 3, 0};
        final int[] i = {0};
        timer.addActionListener(e -> {
            if (i[0] < steps.length) {
                setLocation(origin.x + steps[i[0]], origin.y);
                i[0]++;
            } else {
                setLocation(origin);
                timer.stop();
            }
        });
        timer.start();
    }
}
