        JButton btnRemove = accentBtn("Remove Selected", DANGER);
        JButton btnSearch = accentBtn("Search by Name", ACCENT);

        btnAdd.addActionListener(e -> {
            try {
                String nm = tfName.getText().trim();
                int age = Integer.parseInt(tfAge.getText().trim());
                String diag = tfDiag.getText().trim(), hist = tfHist.getText().trim();
                if (nm.isEmpty()) { status("Enter a patient name."); return; }
                patientRecords.addPatient(nm, age, diag, hist);
                refreshPatients();
                refreshDashboard();
