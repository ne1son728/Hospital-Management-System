    // ── Emergency ─────────────────────────────────────────────────────────────

    JPanel buildEmergencyPanel() {
        JPanel p = new JPanel(new BorderLayout(0, 14));
        p.setBackground(BG); p.setBorder(new EmptyBorder(28, 28, 28, 28));
        JLabel header = new JLabel("Emergency Patient Prioritization");
        header.setFont(new Font("Segoe UI", Font.BOLD, 22)); header.setForeground(TEXT); p.add(header, BorderLayout.NORTH);

        String[] cols = {"Patient Name", "Severity (1-10)", "Added At", "Added By"};
        emergencyModel = new DefaultTableModel(cols, 0) { public boolean isCellEditable(int r, int c) { return false; } };
        JTable table = styledTable(emergencyModel);
        table.getColumnModel().getColumn(1).setCellRenderer(new DefaultTableCellRenderer() {
            public Component getTableCellRendererComponent(JTable t, Object v, boolean sel, boolean foc, int row, int col) {
                super.getTableCellRendererComponent(t, v, sel, foc, row, col);
                setHorizontalAlignment(CENTER);
                int sev = (Integer) v;
                setForeground(sev >= 8 ? DANGER : sev >= 5 ? WARNING : SUCCESS);
                setBackground(sel ? ACCENT : (row % 2 == 0 ? CARD : new Color(224, 238, 252)));
                return this;
            }
        });
        table.getColumnModel().getColumn(2).setPreferredWidth(150);
        refreshEmergency();

        JPanel form = new JPanel(new FlowLayout(FlowLayout.LEFT, 8, 8));
        form.setBackground(CARD);
        form.setBorder(BorderFactory.createCompoundBorder(BorderFactory.createLineBorder(BORDER), new EmptyBorder(8,8,8,8)));
        JTextField tfName = field(); tfName.setPreferredSize(new Dimension(180, 32));
        JSpinner spSev = new JSpinner(new SpinnerNumberModel(5, 1, 10, 1));
        spSev.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        ((JSpinner.DefaultEditor) spSev.getEditor()).getTextField().setBackground(new Color(240, 247, 255));
        ((JSpinner.DefaultEditor) spSev.getEditor()).getTextField().setForeground(TEXT);

        JButton btnAdd      = accentBtn("Add Emergency Patient",  DANGER);
        JButton btnServe    = accentBtn("Serve Highest Priority", ACCENT);
        JButton btnResolved = accentBtn("View Resolved",          SUCCESS);

        btnAdd.setEnabled(currentUser.role.canAddEmergencyPatient());
        btnServe.setEnabled(currentUser.role.canServeEmergencyPatient());
        if (!currentUser.role.canAddEmergencyPatient())   btnAdd.setToolTipText("Receptionists cannot add emergency patients");
        if (!currentUser.role.canServeEmergencyPatient()) btnServe.setToolTipText("Receptionists cannot serve emergency patients");

        btnAdd.addActionListener(e -> {
            if (!currentUser.role.canAddEmergencyPatient()) { status("Access denied."); return; }
            String nm = tfName.getText().trim(); int sev = (Integer) spSev.getValue();
            if (nm.isEmpty()) { status("Enter patient name."); return; }
            addEmergencyAndPersist(nm, sev, currentUser.username);
            logAndPersist(currentUser.username, currentUser.role.displayName, "Added emergency patient: " + nm + " (severity " + sev + ")");
            refreshEmergency(); refreshDashboard(); tfName.setText("");
            status("Emergency patient '" + nm + "' added and saved (severity " + sev + ")");
        });

        btnServe.addActionListener(e -> {
            if (!currentUser.role.canServeEmergencyPatient()) { status("Access denied."); return; }
            EmergencyPatientPrioritization.EP next = emergency.serveNext();
            if (next != null) {
                db.updateEmergencyResolved(next);
                logAndPersist(currentUser.username, currentUser.role.displayName,
                        "Served emergency patient: " + next.name + " (severity " + next.severity + ", added " + next.addedAt + ")");
                refreshEmergency(); refreshDashboard(); status("Served: " + next.name);
                JOptionPane.showMessageDialog(this,
                        "Serving: " + next.name + "\nSeverity: " + next.severity +
                                "\nAdded at: " + next.addedAt + "\nAdded by: " + next.addedBy,
                        "Emergency Served", JOptionPane.WARNING_MESSAGE);
            } else { status("No emergency patients."); }
        });

        btnResolved.addActionListener(e -> showResolvedEmergencies());

        form.add(label("Patient Name:")); form.add(tfName);
        form.add(label("Severity:")); form.add(spSev);
        form.add(btnAdd); form.add(btnServe); form.add(btnResolved);
        p.add(styledScroll(table), BorderLayout.CENTER); p.add(form, BorderLayout.SOUTH);
        return p;
    }

    void refreshEmergency() {
        if (emergencyModel == null) return;
        emergencyModel.setRowCount(0);
        for (EmergencyPatientPrioritization.EP ep : emergency.getAll())
            emergencyModel.addRow(new Object[]{ep.name, ep.severity, ep.addedAt, ep.addedBy});
    }

    void showResolvedEmergencies() {
        List<EmergencyPatientPrioritization.EP> resolved = emergency.getResolved();
        JDialog dlg = new JDialog(this, "Resolved Emergency Cases", true);
        dlg.setSize(620, 340); dlg.setLocationRelativeTo(this);
        dlg.getContentPane().setBackground(BG); dlg.setLayout(new BorderLayout());
        JLabel h = new JLabel("  Resolved Emergency Cases (" + resolved.size() + " total)");
        h.setFont(new Font("Segoe UI", Font.BOLD, 16)); h.setForeground(TEXT);
        h.setBorder(new EmptyBorder(16,16,12,16)); dlg.add(h, BorderLayout.NORTH);
        if (resolved.isEmpty()) {
            JLabel none = new JLabel("No resolved cases yet.", SwingConstants.CENTER);
            none.setForeground(SUBTEXT); none.setFont(new Font("Segoe UI", Font.PLAIN, 13));
            dlg.add(none, BorderLayout.CENTER);
        } else {
            String[] cols = {"Patient", "Severity", "Added At", "Added By"};
            DefaultTableModel mdl = new DefaultTableModel(cols, 0) { public boolean isCellEditable(int r, int c) { return false; } };
            List<EmergencyPatientPrioritization.EP> rev = new ArrayList<>(resolved); Collections.reverse(rev);
            for (EmergencyPatientPrioritization.EP ep : rev)
                mdl.addRow(new Object[]{ep.name, ep.severity, ep.addedAt, ep.addedBy});
            dlg.add(styledScroll(styledTable(mdl)), BorderLayout.CENTER);
        }
        JButton close = accentBtn("Close", ACCENT); close.addActionListener(ev -> dlg.dispose());
        JPanel foot = new JPanel(new FlowLayout(FlowLayout.RIGHT));
        foot.setBackground(BG); foot.setBorder(new EmptyBorder(8,16,12,16)); foot.add(close);
        dlg.add(foot, BorderLayout.SOUTH); dlg.setVisible(true);
    }

