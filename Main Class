// ─── Enums & Role System ─────────────────────────────────────────────────────

enum Role {
    ADMIN("Admin", new Color(0, 120, 212)),
    RECEPTIONIST("Receptionist", new Color(0, 153, 102)),
    NURSE("Nurse", new Color(150, 60, 180));

    final String displayName;
    final Color badgeColor;
    Role(String displayName, Color badgeColor) {
        this.displayName = displayName;
        this.badgeColor = badgeColor;
    }

    boolean canAddPatient()            { return this == ADMIN || this == RECEPTIONIST || this == NURSE; }
    boolean canRemovePatient()         { return this == ADMIN; }
    boolean canAddDoctor()             { return this == ADMIN; }
    boolean canSearchDoctor()          { return this == ADMIN || this == RECEPTIONIST || this == NURSE; }
    boolean canScheduleAppointment()   { return this == ADMIN || this == RECEPTIONIST; }
    boolean canServeAppointment()      { return this == ADMIN || this == RECEPTIONIST; }
    boolean canAddEmergencyPatient()   { return this == ADMIN || this == NURSE; }
    boolean canServeEmergencyPatient() { return this == ADMIN || this == NURSE; }
    boolean canViewAuditLog()          { return this == ADMIN; }
}

class UserAccount {
    final String username;
    final String password;
    final Role role;
    UserAccount(String username, String password, Role role) {
        this.username = username;
        this.password = password;
        this.role = role;
