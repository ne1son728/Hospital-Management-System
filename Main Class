    void refreshAppointments() {
        if (appointmentModel == null) return;
        appointmentModel.setRowCount(0);
        List<AppointmentRecord> list = appointments.getQueue();
        for (int i = 0; i < list.size(); i++) {
            AppointmentRecord r = list.get(i);
            appointmentModel.addRow(new Object[]{i + 1, r.patientName, r.scheduledAt, r.scheduledBy});
        }
    }

    void showCompletedAppointments() {
        List<AppointmentRecord> completed = appointments.getCompleted();
        JDialog dlg = new JDialog(this, "Completed Appointments", true);
        dlg.setSize(700, 340); dlg.setLocationRelativeTo(this);
        dlg.getContentPane().setBackground(BG); dlg.setLayout(new BorderLayout());
        JLabel h = new JLabel("  Completed Appointments (" + completed.size() + " total)");
        h.setFont(new Font("Segoe UI", Font.BOLD, 16)); h.setForeground(TEXT);
        h.setBorder(new EmptyBorder(16,16,12,16)); dlg.add(h, BorderLayout.NORTH);
        if (completed.isEmpty()) {
            JLabel none = new JLabel("No completed appointments yet.", SwingConstants.CENTER);
            none.setForeground(SUBTEXT); none.setFont(new Font("Segoe UI", Font.PLAIN, 13));
            dlg.add(none, BorderLayout.CENTER);
        } else {
            String[] cols = {"Patient", "Scheduled At", "Scheduled By", "Served At", "Served By"};
            DefaultTableModel mdl = new DefaultTableModel(cols, 0) { public boolean isCellEditable(int r, int c) { return false; } };
            List<AppointmentRecord> rev = new ArrayList<>(completed); Collections.reverse(rev);
            for (AppointmentRecord r : rev)
