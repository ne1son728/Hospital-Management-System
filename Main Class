// ─── Data Classes ────────────────────────────────────────────────────────────

class Patient {
    String name, diagnosis, treatmentHistory;
    int age;
    Patient next;
    public Patient(String name, int age, String diagnosis, String treatmentHistory) {
        this.name = name; this.age = age;
        this.diagnosis = diagnosis; this.treatmentHistory = treatmentHistory;
    }
}

class PatientRecordManagement {
    private Patient head;
    public void addPatient(String name, int age, String diagnosis, String history) {
        Patient p = new Patient(name, age, diagnosis, history);
        p.next = head; head = p;
    }
    public Patient getPatient(String name) {
        Patient cur = head;
        while (cur != null) { if (cur.name.equalsIgnoreCase(name)) return cur; cur = cur.next; }
        return null;
    }
    public boolean removePatient(String name) {
        if (head == null) return false;
        if (head.name.equalsIgnoreCase(name)) { head = head.next; return true; }
        Patient cur = head;
        while (cur.next != null) {
            if (cur.next.name.equalsIgnoreCase(name)) { cur.next = cur.next.next; return true; }
            cur = cur.next;
        }
        return false;
    }
    public java.util.List<Patient> getAllPatients() {
        java.util.List<Patient> list = new ArrayList<>();
        Patient cur = head;
        while (cur != null) { list.add(cur); cur = cur.next; }
        return list;
    }
}

class Doctor {
    String id, name, specialization, availableHours, availability;
    public Doctor(String id, String name, String specialization, String availableHours, String availability) {
        this.id = id; this.name = name; this.specialization = specialization;
        this.availableHours = availableHours; this.availability = availability;
    }
}

class DoctorManagement {
    private HashMap<String, Doctor> doctors = new HashMap<>();
    private static final String[] MONTHS = {"Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"};
    public void addDoctor(String id, String name, String spec, String hours) {
        Random r = new Random();
        int s = r.nextInt(MONTHS.length), e = r.nextInt(MONTHS.length - s) + s;
        doctors.put(id, new Doctor(id, name, spec, hours, MONTHS[s] + "-" + MONTHS[e]));
    }
    public Doctor getDoctor(String id) { return doctors.get(id); }
    public java.util.List<Doctor> getAllDoctors() { return new ArrayList<>(doctors.values()); }
}

class AppointmentScheduling {
    private Queue<String> queue = new LinkedList<>();
    public void schedule(String name) { queue.add(name); }
    public String serveNext() { return queue.poll(); }
    public java.util.List<String> getAll() { return new ArrayList<>(queue); }
    public boolean contains(String name) { return queue.contains(name); }
}

class EmergencyPatientPrioritization {
    static class EP { String name; int severity;
        EP(String n, int s) { name = n; severity = s; } }
    private PriorityQueue<EP> pq = new PriorityQueue<>(Comparator.comparingInt(e -> -e.severity));
    public void add(String name, int severity) { pq.add(new EP(name, severity)); }
    public EP serveNext() { return pq.poll(); }
    public java.util.List<EP> getAll() { return new ArrayList<>(pq); }
}

