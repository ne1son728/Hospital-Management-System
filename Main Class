            JLabel row = new JLabel(ua.username + " / " + ua.password + "  →  " + ua.role.displayName);
            row.setFont(new Font("Monospaced", Font.PLAIN, 11)); row.setForeground(ua.role.badgeColor); legend.add(row);
        }

        JLabel userLabel = new JLabel("Username");
        userLabel.setFont(new Font("Segoe UI", Font.BOLD, 12)); userLabel.setForeground(SUBTEXT); userLabel.setAlignmentX(LEFT_ALIGNMENT);
        JPanel userRow = new JPanel(new BorderLayout(6, 0));
        userRow.setBackground(CARD); userRow.setMaximumSize(new Dimension(320, 38)); userRow.setAlignmentX(LEFT_ALIGNMENT);
        usernameField = new JTextField(); styleField(usernameField);
