    // ── Load / Seed ───────────────────────────────────────────────────────────

    void loadFromDatabase() {
        if (db.isEmpty()) {
            seedDemoData();
        } else {
            for (Patient p : db.loadPatients()) patientRecords.addPatientDirect(p);
            for (Doctor d : db.loadDoctors())   doctorMgmt.addDoctorDirect(d);
            for (AppointmentRecord r : db.loadAppointments()) appointments.addDirect(r);
            for (EmergencyPatientPrioritization.EP ep : db.loadEmergency()) emergency.addDirect(ep);
            for (AuditEntry e : db.loadAuditLog()) auditLog.add(e);
        }
    }

    /** Runs only on the very first launch when hospital.db is empty. */
    void seedDemoData() {
        addPatientAndPersist("Alice Johnson", 34, "Hypertension",    "Beta-blockers",   "system");
        addPatientAndPersist("Bob Smith",     55, "Diabetes Type 2", "Metformin",       "system");
        addPatientAndPersist("Carol White",   28, "Asthma",          "Inhaler therapy", "system");

        doctorMgmt.addDoctor("D001", "Dr. Emily Chen",  "Cardiology", "9AM-5PM");
        doctorMgmt.addDoctor("D002", "Dr. James Patel", "Neurology",  "10AM-6PM");
        doctorMgmt.addDoctor("D003", "Dr. Sarah Kim",   "Oncology",   "8AM-4PM");
        for (Doctor d : doctorMgmt.getAllDoctors()) db.insertDoctor(d);

        scheduleAndPersist("Alice Johnson", "system");
        scheduleAndPersist("Bob Smith",     "system");
        addEmergencyAndPersist("Carol White", 8, "system");
        addEmergencyAndPersist("John Doe",    5, "system");
        logAndPersist("system", "System", "Demo data seeded on first launch");
    }

    // ── Write-through helpers (memory + DB in one call) ───────────────────────

    void addPatientAndPersist(String name, int age, String diag, String hist, String by) {
        patientRecords.addPatient(name, age, diag, hist, by);
        Patient p = patientRecords.getPatient(name);
        if (p != null) db.insertPatient(p);
    }

    void scheduleAndPersist(String name, String by) {
        AppointmentRecord r = new AppointmentRecord(name, by);
        r.id = db.insertAppointment(r); // get DB-generated id
        appointments.addDirect(r);      // enqueue the id-bearing record
    }

    void addEmergencyAndPersist(String name, int severity, String by) {
        EmergencyPatientPrioritization.EP ep = new EmergencyPatientPrioritization.EP(name, severity, by);
        ep.id = db.insertEmergency(ep);
        emergency.addDirect(ep);
    }

    void logAndPersist(String actor, String role, String action) {
        AuditEntry e = new AuditEntry(actor, role, action);
        auditLog.add(e);
        db.insertAuditEntry(e);
        refreshAuditLog();
    }

