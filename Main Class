            refreshAppointments(); refreshDashboard(); tfName.setText("");
            status("Appointment scheduled and saved for " + nm);
        });

        btnServe.addActionListener(e -> {
            if (!currentUser.role.canServeAppointment()) { status("Access denied."); return; }
            if (appointments.getQueue().isEmpty()) { status("No appointments in queue."); return; }
