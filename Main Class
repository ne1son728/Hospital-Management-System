// ─── Timestamp ────────────────────────────────────────────────────────────────

class Timestamp {
    private static final DateTimeFormatter FMT = DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss");
    static String now() { return LocalDateTime.now().format(FMT); }
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

class AuditEntry {
    final String timestamp, actor, role, action;
    AuditEntry(String timestamp, String actor, String role, String action) {
        this.timestamp = timestamp; this.actor = actor;
        this.role = role; this.action = action;
    }
    AuditEntry(String actor, String role, String action) {
        this(Timestamp.now(), actor, role, action);
    }
}

class AuditLog {
    private final List<AuditEntry> entries = new ArrayList<>();
    void add(AuditEntry e) { entries.add(0, e); }
    void log(String actor, String role, String action) { entries.add(0, new AuditEntry(actor, role, action)); }
    List<AuditEntry> getAll() { return Collections.unmodifiableList(entries); }
}

// ─── Data Classes ─────────────────────────────────────────────────────────────

class AppointmentRecord {
    int id; // DB primary key; -1 = not yet persisted
    final String patientName;
    final String scheduledAt;
    final String scheduledBy;
    String servedAt;
    String servedBy;
    boolean served;

    // Brand-new record (not yet in DB)
    AppointmentRecord(String patientName, String scheduledBy) {
        this.id = -1;
        this.patientName = patientName;
        this.scheduledAt = Timestamp.now();
        this.scheduledBy = scheduledBy;
        this.served = false;
    }

    // Loaded from DB
    AppointmentRecord(int id, String patientName, String scheduledAt, String scheduledBy,
                      String servedAt, String servedBy, boolean served) {
        this.id = id; this.patientName = patientName;
        this.scheduledAt = scheduledAt; this.scheduledBy = scheduledBy;
        this.servedAt = servedAt; this.servedBy = servedBy; this.served = served;
    }

    void markServed(String servedBy) {
        this.servedAt = Timestamp.now();
        this.servedBy = servedBy;
        this.served = true;
    }
}

class Patient {
    String name, diagnosis, treatmentHistory;
    int age;
    String addedAt, addedBy;
    Patient next;

    Patient(String name, int age, String diagnosis, String treatmentHistory, String addedBy) {
        this.name = name; this.age = age;
        this.diagnosis = diagnosis; this.treatmentHistory = treatmentHistory;
        this.addedAt = Timestamp.now(); this.addedBy = addedBy;
    }
    // Load from DB (timestamp already known)
    Patient(String name, int age, String diagnosis, String treatmentHistory, String addedAt, String addedBy) {
        this.name = name; this.age = age;
        this.diagnosis = diagnosis; this.treatmentHistory = treatmentHistory;
        this.addedAt = addedAt; this.addedBy = addedBy;
    }
}

class PatientRecordManagement {
    private Patient head;

    void addPatientDirect(Patient p) { p.next = head; head = p; }

    void addPatient(String name, int age, String diagnosis, String history, String addedBy) {
        Patient p = new Patient(name, age, diagnosis, history, addedBy);
        p.next = head; head = p;
    }

    Patient getPatient(String name) {
        Patient cur = head;
        while (cur != null) { if (cur.name.equalsIgnoreCase(name)) return cur; cur = cur.next; }
        return null;
    }

    boolean removePatient(String name) {
        if (head == null) return false;
        if (head.name.equalsIgnoreCase(name)) { head = head.next; return true; }
        Patient cur = head;
        while (cur.next != null) {
            if (cur.next.name.equalsIgnoreCase(name)) { cur.next = cur.next.next; return true; }
            cur = cur.next;
        }
        return false;
    }

    List<Patient> getAllPatients() {
        List<Patient> list = new ArrayList<>();
        Patient cur = head;
        while (cur != null) { list.add(cur); cur = cur.next; }
        return list;
    }
}

class Doctor {
    String id, name, specialization, availableHours, availability, addedAt;

    Doctor(String id, String name, String specialization, String availableHours, String availability) {
        this.id = id; this.name = name; this.specialization = specialization;
        this.availableHours = availableHours; this.availability = availability;
        this.addedAt = Timestamp.now();
    }
    // Load from DB
    Doctor(String id, String name, String specialization, String availableHours, String availability, String addedAt) {
        this.id = id; this.name = name; this.specialization = specialization;
        this.availableHours = availableHours; this.availability = availability;
        this.addedAt = addedAt;
    }
}

class DoctorManagement {
    private final HashMap<String, Doctor> doctors = new HashMap<>();
    private static final String[] MONTHS = {"Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"};

    void addDoctor(String id, String name, String spec, String hours) {
        Random r = new Random();
        int s = r.nextInt(MONTHS.length), e = r.nextInt(MONTHS.length - s) + s;
        doctors.put(id, new Doctor(id, name, spec, hours, MONTHS[s] + "-" + MONTHS[e]));
    }

    void addDoctorDirect(Doctor d) { doctors.put(d.id, d); }

    Doctor getDoctor(String id) { return doctors.get(id); }
    List<Doctor> getAllDoctors() { return new ArrayList<>(doctors.values()); }
}

class AppointmentScheduling {
    private final Queue<AppointmentRecord> queue = new LinkedList<>();
    private final List<AppointmentRecord> completed = new ArrayList<>();

    void schedule(String name, String scheduledBy) { queue.add(new AppointmentRecord(name, scheduledBy)); }

    void addDirect(AppointmentRecord r) {
        if (r.served) completed.add(r); else queue.add(r);
    }

    AppointmentRecord serveNext(String servedBy) {
        AppointmentRecord rec = queue.poll();
        if (rec != null) { rec.markServed(servedBy); completed.add(rec); }
        return rec;
    }

    List<AppointmentRecord> getQueue()     { return new ArrayList<>(queue); }
    List<AppointmentRecord> getCompleted() { return Collections.unmodifiableList(completed); }

    boolean containsName(String name) {
        return queue.stream().anyMatch(r -> r.patientName.equalsIgnoreCase(name));
    }

    List<AppointmentRecord> getHistoryForPatient(String name) {
        List<AppointmentRecord> all = new ArrayList<>();
        for (AppointmentRecord r : queue)     if (r.patientName.equalsIgnoreCase(name)) all.add(r);
        for (AppointmentRecord r : completed) if (r.patientName.equalsIgnoreCase(name)) all.add(r);
        return all;
    }
}

class EmergencyPatientPrioritization {
    static class EP {
        int id;
        String name, addedAt, addedBy;
        int severity;
        boolean resolved;

        EP(String name, int severity, String addedBy) {
            this.id = -1; this.name = name; this.severity = severity;
            this.addedAt = Timestamp.now(); this.addedBy = addedBy; this.resolved = false;
        }
        EP(int id, String name, int severity, String addedAt, String addedBy, boolean resolved) {
            this.id = id; this.name = name; this.severity = severity;
            this.addedAt = addedAt; this.addedBy = addedBy; this.resolved = resolved;
        }
    }

    private final PriorityQueue<EP> pq = new PriorityQueue<>(Comparator.comparingInt(e -> -e.severity));
    private final List<EP> resolved = new ArrayList<>();

    void add(String name, int severity, String addedBy) { pq.add(new EP(name, severity, addedBy)); }
    void addDirect(EP ep) { if (ep.resolved) resolved.add(ep); else pq.add(ep); }

    EP serveNext() {
        EP ep = pq.poll();
        if (ep != null) { ep.resolved = true; resolved.add(ep); }
        return ep;
    }

    List<EP> getAll()      { return new ArrayList<>(pq); }
    List<EP> getResolved() { return Collections.unmodifiableList(resolved); }
}

// ─── Database Layer ───────────────────────────────────────────────────────────

class Database {
    private static final String DB_FILE = "hospital.db";
    private static final String URL     = "jdbc:sqlite:" + DB_FILE;
    private Connection conn;

    Database() {
        try {
            Class.forName("org.sqlite.JDBC");
            conn = DriverManager.getConnection(URL);
            try (Statement st = conn.createStatement()) {
                st.execute("PRAGMA journal_mode=WAL;");
                st.execute("PRAGMA foreign_keys=ON;");
            }
            createTables();
        } catch (Exception e) {
            throw new RuntimeException("Failed to open database: " + e.getMessage(), e);
        }
    }

    // ── Schema ────────────────────────────────────────────────────────────────

    private void createTables() throws SQLException {
        try (Statement st = conn.createStatement()) {
            st.executeUpdate(
                    "CREATE TABLE IF NOT EXISTS patients (" +
                            "  name TEXT PRIMARY KEY," +
                            "  age INTEGER NOT NULL," +
                            "  diagnosis TEXT," +
                            "  treatment_history TEXT," +
                            "  added_at TEXT NOT NULL," +
                            "  added_by TEXT NOT NULL" +
                            ");"
            );
            st.executeUpdate(
                    "CREATE TABLE IF NOT EXISTS doctors (" +
                            "  id TEXT PRIMARY KEY," +
                            "  name TEXT NOT NULL," +
                            "  specialization TEXT," +
                            "  available_hours TEXT," +
                            "  availability TEXT," +
                            "  added_at TEXT NOT NULL" +
                            ");"
            );
            st.executeUpdate(
                    "CREATE TABLE IF NOT EXISTS appointments (" +
                            "  id INTEGER PRIMARY KEY AUTOINCREMENT," +
                            "  patient_name TEXT NOT NULL," +
                            "  scheduled_at TEXT NOT NULL," +
                            "  scheduled_by TEXT NOT NULL," +
                            "  served_at TEXT," +
                            "  served_by TEXT," +
                            "  served INTEGER NOT NULL DEFAULT 0" +
                            ");"
            );
            st.executeUpdate(
                    "CREATE TABLE IF NOT EXISTS emergency_patients (" +
                            "  id INTEGER PRIMARY KEY AUTOINCREMENT," +
                            "  name TEXT NOT NULL," +
                            "  severity INTEGER NOT NULL," +
                            "  added_at TEXT NOT NULL," +
                            "  added_by TEXT NOT NULL," +
                            "  resolved INTEGER NOT NULL DEFAULT 0" +
                            ");"
            );
            st.executeUpdate(
                    "CREATE TABLE IF NOT EXISTS audit_log (" +
                            "  id INTEGER PRIMARY KEY AUTOINCREMENT," +
                            "  timestamp TEXT NOT NULL," +
                            "  actor TEXT NOT NULL," +
                            "  role TEXT NOT NULL," +
                            "  action TEXT NOT NULL" +
                            ");"
            );
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    /** Returns true when the DB has never had data written to it (first launch). */
    boolean isEmpty() {
        try (Statement st = conn.createStatement();
             ResultSet rs = st.executeQuery("SELECT COUNT(*) FROM patients")) {
            return rs.next() && rs.getInt(1) == 0;
        } catch (SQLException e) { return true; }
    }

    void close() {
        try { if (conn != null && !conn.isClosed()) conn.close(); }
        catch (SQLException e) { e.printStackTrace(); }
    }

    // ── Patients ──────────────────────────────────────────────────────────────

    void insertPatient(Patient p) {
        String sql = "INSERT OR IGNORE INTO patients(name,age,diagnosis,treatment_history,added_at,added_by) VALUES(?,?,?,?,?,?)";
        try (PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setString(1, p.name);  ps.setInt(2, p.age);
            ps.setString(3, p.diagnosis); ps.setString(4, p.treatmentHistory);
            ps.setString(5, p.addedAt);   ps.setString(6, p.addedBy);
            ps.executeUpdate();
        } catch (SQLException e) { e.printStackTrace(); }
    }

    void deletePatient(String name) {
        try (PreparedStatement ps = conn.prepareStatement("DELETE FROM patients WHERE name=?")) {
            ps.setString(1, name); ps.executeUpdate();
        } catch (SQLException e) { e.printStackTrace(); }
    }

    List<Patient> loadPatients() {
        List<Patient> list = new ArrayList<>();
        try (Statement st = conn.createStatement();
             ResultSet rs = st.executeQuery("SELECT * FROM patients ORDER BY added_at DESC")) {
            while (rs.next())
                list.add(new Patient(
                        rs.getString("name"), rs.getInt("age"),
                        rs.getString("diagnosis"), rs.getString("treatment_history"),
                        rs.getString("added_at"), rs.getString("added_by")
                ));
        } catch (SQLException e) { e.printStackTrace(); }
        return list;
    }

    // ── Doctors ───────────────────────────────────────────────────────────────

    void insertDoctor(Doctor d) {
        String sql = "INSERT OR IGNORE INTO doctors(id,name,specialization,available_hours,availability,added_at) VALUES(?,?,?,?,?,?)";
        try (PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setString(1, d.id);    ps.setString(2, d.name);
            ps.setString(3, d.specialization); ps.setString(4, d.availableHours);
            ps.setString(5, d.availability);   ps.setString(6, d.addedAt);
            ps.executeUpdate();
        } catch (SQLException e) { e.printStackTrace(); }
    }

    List<Doctor> loadDoctors() {
        List<Doctor> list = new ArrayList<>();
        try (Statement st = conn.createStatement();
             ResultSet rs = st.executeQuery("SELECT * FROM doctors ORDER BY added_at DESC")) {
            while (rs.next())
                list.add(new Doctor(
                        rs.getString("id"), rs.getString("name"),
                        rs.getString("specialization"), rs.getString("available_hours"),
                        rs.getString("availability"), rs.getString("added_at")
                ));
        } catch (SQLException e) { e.printStackTrace(); }
        return list;
    }

    // ── Appointments ──────────────────────────────────────────────────────────

    /** Inserts a new pending appointment row and returns its generated id. */
    int insertAppointment(AppointmentRecord r) {
        String sql = "INSERT INTO appointments(patient_name,scheduled_at,scheduled_by,served) VALUES(?,?,?,0)";
        try (PreparedStatement ps = conn.prepareStatement(sql, Statement.RETURN_GENERATED_KEYS)) {
            ps.setString(1, r.patientName);
            ps.setString(2, r.scheduledAt);
            ps.setString(3, r.scheduledBy);
            ps.executeUpdate();
            ResultSet keys = ps.getGeneratedKeys();
            if (keys.next()) return keys.getInt(1);
        } catch (SQLException e) { e.printStackTrace(); }
        return -1;
    }

    /** Marks an existing appointment row as served. */
    void updateAppointmentServed(AppointmentRecord r) {
        String sql = "UPDATE appointments SET served=1, served_at=?, served_by=? WHERE id=?";
        try (PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setString(1, r.servedAt);
            ps.setString(2, r.servedBy);
            ps.setInt(3, r.id);
            ps.executeUpdate();
        } catch (SQLException e) { e.printStackTrace(); }
    }

    List<AppointmentRecord> loadAppointments() {
        List<AppointmentRecord> list = new ArrayList<>();
        try (Statement st = conn.createStatement();
             ResultSet rs = st.executeQuery("SELECT * FROM appointments ORDER BY id ASC")) {
            while (rs.next())
                list.add(new AppointmentRecord(
                        rs.getInt("id"),
                        rs.getString("patient_name"),
                        rs.getString("scheduled_at"),
                        rs.getString("scheduled_by"),
                        rs.getString("served_at"),
                        rs.getString("served_by"),
                        rs.getInt("served") == 1
                ));
        } catch (SQLException e) { e.printStackTrace(); }
        return list;
    }

    // ── Emergency ─────────────────────────────────────────────────────────────

    int insertEmergency(EmergencyPatientPrioritization.EP ep) {
        String sql = "INSERT INTO emergency_patients(name,severity,added_at,added_by,resolved) VALUES(?,?,?,?,0)";
        try (PreparedStatement ps = conn.prepareStatement(sql, Statement.RETURN_GENERATED_KEYS)) {
            ps.setString(1, ep.name); ps.setInt(2, ep.severity);
            ps.setString(3, ep.addedAt); ps.setString(4, ep.addedBy);
            ps.executeUpdate();
            ResultSet keys = ps.getGeneratedKeys();
            if (keys.next()) return keys.getInt(1);
        } catch (SQLException e) { e.printStackTrace(); }
        return -1;
    }

    void updateEmergencyResolved(EmergencyPatientPrioritization.EP ep) {
        try (PreparedStatement ps = conn.prepareStatement("UPDATE emergency_patients SET resolved=1 WHERE id=?")) {
            ps.setInt(1, ep.id); ps.executeUpdate();
        } catch (SQLException e) { e.printStackTrace(); }
    }

    List<EmergencyPatientPrioritization.EP> loadEmergency() {
        List<EmergencyPatientPrioritization.EP> list = new ArrayList<>();
        try (Statement st = conn.createStatement();
             ResultSet rs = st.executeQuery("SELECT * FROM emergency_patients ORDER BY id ASC")) {
            while (rs.next())
                list.add(new EmergencyPatientPrioritization.EP(
                        rs.getInt("id"), rs.getString("name"), rs.getInt("severity"),
                        rs.getString("added_at"), rs.getString("added_by"),
                        rs.getInt("resolved") == 1
                ));
        } catch (SQLException e) { e.printStackTrace(); }
        return list;
    }

    // ── Audit Log ─────────────────────────────────────────────────────────────

    void insertAuditEntry(AuditEntry e) {
        String sql = "INSERT INTO audit_log(timestamp,actor,role,action) VALUES(?,?,?,?)";
        try (PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setString(1, e.timestamp); ps.setString(2, e.actor);
            ps.setString(3, e.role);      ps.setString(4, e.action);
            ps.executeUpdate();
        } catch (SQLException ex) { ex.printStackTrace(); }
    }

    List<AuditEntry> loadAuditLog() {
        List<AuditEntry> list = new ArrayList<>();
        try (Statement st = conn.createStatement();
             ResultSet rs = st.executeQuery("SELECT * FROM audit_log ORDER BY id DESC")) {
            while (rs.next())
                list.add(new AuditEntry(
                        rs.getString("timestamp"), rs.getString("actor"),
                        rs.getString("role"), rs.getString("action")
                ));
        } catch (SQLException e) { e.printStackTrace(); }
        return list;
    }
}

